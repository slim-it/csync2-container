{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "dependencyDashboard": false,
  "customManagers": [
    {
      "customType": "regex",
      "description": "VERSION holds the packaged csync2 apt version, tracked against the Ubuntu archive of the release the base image pins.",
      "managerFilePatterns": [
        "/^VERSION$/"
      ],
      "matchStrings": [
        "(?<currentValue>.+)\\n"
      ],
      "depNameTemplate": "csync2",
      "datasourceTemplate": "deb",
      "versioningTemplate": "deb"
    },
    {
      "customType": "regex",
      "description": "The suite codenames are the same Ubuntu release the FROM line pins; tracked as one dependency and grouped so a release bump moves both files in one PR. That PR stays red until the follow-up csync2 VERSION update against the new suites lands.",
      "managerFilePatterns": [
        "/^renovate\\.json$/"
      ],
      "matchStrings": [
        "suite=(?<currentValue>[a-z]+)(?:-updates|-security)?&"
      ],
      "depNameTemplate": "ubuntu",
      "packageNameTemplate": "ubuntu",
      "datasourceTemplate": "docker",
      "versioningTemplate": "ubuntu"
    }
  ],
  "packageRules": [
    {
      "description": "Look csync2 up in the release, updates, and security suites",
      "matchDepNames": [
        "csync2"
      ],
      "registryUrls": [
        "https://archive.ubuntu.com/ubuntu?suite=resolute&components=main,universe&binaryArch=amd64",
        "https://archive.ubuntu.com/ubuntu?suite=resolute-updates&components=main,universe&binaryArch=amd64",
        "https://archive.ubuntu.com/ubuntu?suite=resolute-security&components=main,universe&binaryArch=amd64"
      ]
    },
    {
      "description": "Move the base image and the tracked suites in one PR",
      "matchDepNames": [
        "ubuntu"
      ],
      "versioning": "ubuntu",
      "groupName": "ubuntu-release"
    }
  ]
}
